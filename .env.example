# Dhan Trading API Configuration
DHAN_BASE_URL=https://api.dhan.co/v2
# Get your access token from Dhan trading platform (for trading operations)
DHAN_ACCESS_TOKEN=<set_in_local_env_or_secret_manager>
# Get your data access token from Dhan platform (for market data operations)
DHAN_DATA_ACCESS_TOKEN=<set_in_local_env_or_secret_manager>
# Your Dhan client ID
DHAN_CLIENT_ID=your_client_id_here
# Public client ID for client-side components
NEXT_PUBLIC_DHAN_CLIENT_ID=your_client_id_here

# Example: DHAN_ACCESS_TOKEN=<paste_token_from_env_or_secret_manager>
# Example: DHAN_DATA_ACCESS_TOKEN=<paste_token_from_env_or_secret_manager>
